# ======================================================
# Environment Variables Template
# Copy this file to .env.local (本地开发) or .env.prd (生产部署)
# .env.local / .env.prd must NOT be committed to version control
# ======================================================

# ---- 通用 ----
SPRING_PROFILES_ACTIVE=dev

# ---- JWT（所有服务共用同一个 secret）----
JWT_SECRET=mySecureSecretKeyForJWTTokenGenerationMustBeAtLeast256BitsLong
JWT_EXPIRATION=86400

# ---- 用户密码 ----
APP_ADMIN_PASSWORD=admin123
APP_USER_PASSWORD=user123

# ---- 服务端口（本地开发默认值，可不填）----
# GATEWAY_HOST_PORT=8080
# AUTH_HOST_PORT=8082
# BUSINESS_HOST_PORT=8083

# ---- 服务地址（本地开发，各自跑 jar 时使用）----
AUTH_SERVICE_URL=http://localhost:8082
BUSINESS_SERVICE_URL=http://localhost:8083

# ---- Docker 生产部署专用 ----
# 镜像仓库地址，例如 registry.cn-hangzhou.aliyuncs.com/yourorg
DOCKER_REGISTRY=localhost
# 镜像版本标签
IMAGE_TAG=latest
